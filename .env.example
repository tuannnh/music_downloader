# Copy to .env and edit. Used for local (non-Docker) runs.

# The copytele/copyparty folder files are written into. MUST end with a slash.
COPYTELE_UPLOAD_URL=https://copytele.zum.vn/music/

# copyparty password. Empty for an open / no-auth volume.
COPYTELE_PW=

# Replace existing files with the same name instead of auto-renaming.
OVERWRITE=false

# Local temp buffer (cleared after each job).
DOWNLOAD_DIR=/tmp/music_downloader

# Netscape-format cookies.txt for TikTok / restricted YouTube. Empty = off.
COOKIES_FILE=

# Max finished jobs kept in memory for status polling.
MAX_JOBS=200

# Server bind.
HOST=0.0.0.0
PORT=8080
