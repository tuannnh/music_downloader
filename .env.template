# Copy to .env and fill in real values.  Do NOT commit .env.

# On the server (CI deploy), point compose at the image pushed to GHCR
# (public image, no login needed). Leave unset for local `docker compose up --build`.
# MUSIC_IMAGE=ghcr.io/tuannnh/music_downloader:latest

# Secret bearer token. Generate a long random one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=replace-with-a-long-random-token

# Public URL of THIS app (baked into the iOS shortcut). e.g. https://music.zum.vn
# Leave blank for local testing; it'll be derived from the request.
PUBLIC_BASE_URL=

# MeTube instance that does the actual downloading.
METUBE_BASE=https://metube.zum.vn
# Max seconds to wait for MeTube to finish a download.
METUBE_TIMEOUT_SEC=600
# How often (seconds) to poll MeTube while waiting.
METUBE_POLL_INTERVAL_SEC=2

# Copytele (copyparty) instance
COPYTELE_BASE=https://copytele.zum.vn
# Base folder/volume on copytele (must start and end with "/").
# A per-source subfolder is appended -> /music/youtube/ , /music/tiktok/
COPYTELE_UPLOAD_PATH=/music/
# Copyparty upload password (sent as the "PW" header).
# Leave BLANK if the upload volume needs no password.
COPYTELE_PW=
